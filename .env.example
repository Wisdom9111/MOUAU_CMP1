# GOOGLE_SHEET_ID: The ID of the Google Sheet for user registrations.
GOOGLE_SHEET_ID="MY_GOOGLE_SHEET_ID"

# GOOGLE_API_KEY: A simple API key for reading from sheets OR use a service account for writing.
# For writing, it's better to use GOOGLE_SERVICE_ACCOUNT_JSON (base64 or direct JSON).
GOOGLE_SERVICE_ACCOUNT_EMAIL="MY_SERVICE_ACCOUNT_EMAIL"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="MY_PRIVATE_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
